# Python
  __pycache__/
  *.pyc
  *.pyo
  *.pyd
  .Python
  *.egg-info/
  .venv/
  venv/
  env/

  # Env / secrets
  .env
  *.env.local

  # IDE
  .vscode/
  .idea/
  .DS_Store

  # Replit (workspace meta — keep out of repo)
  .cache/
  .local/
  .upm/
  .config/
  attached_assets/

  # Project: external copyrighted PDFs (kept out of repo by request)
  proposal_ai/storage/uploads/

  # Logs / tmp
  *.log
  tmp/

  # Data: actual data files (keep README.md tracked, exclude real data)
  proposal_ai/data/winning_proposals/*.pdf
  proposal_ai/data/winning_proposals_pptx/*.pptx
  proposal_ai/data/winning_proposals_pptx/*.ppt
  proposal_ai/data/test_rfps/*.pdf
  proposal_ai/data/processed/
  proposal_ai/data/chroma_db/
  proposal_ai/data/_archive/
