# =========================================================================
# 제안서 자동화 AI 팀 - 환경변수 템플릿
# 실제 사용 시 이 파일을 .env로 복사하거나 Replit Secrets에 등록하세요.
# =========================================================================

# -------------------------------------------------------------------------
# LLM (Replit AI Integrations - 자동 주입됨, 별도 키 불필요)
# -------------------------------------------------------------------------
# 아래 4개는 Replit AI 통합이 자동으로 설정합니다. 직접 설정 X
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=
# AI_INTEGRATIONS_OPENAI_API_KEY=

# -------------------------------------------------------------------------
# 모델 선택 (Replit AI Integrations 가용 모델로 매핑)
# -------------------------------------------------------------------------
MODEL_KIM=gpt-4o-mini
MODEL_LEE=claude-haiku-4-5
MODEL_PARK=claude-opus-4-7
MODEL_CHOI=claude-sonnet-4-6
MODEL_OH=gpt-4o-mini

# -------------------------------------------------------------------------
# 나라장터 G2B OpenAPI (선택) - 발급 방법은 README 참고
# 미설정 시 샘플 데이터로 동작
# -------------------------------------------------------------------------
G2B_SERVICE_KEY=

# -------------------------------------------------------------------------
# Notion API (선택) - 발급 방법은 README 참고
# 미설정 시 SQLite 로컬 게이트로 fallback
# -------------------------------------------------------------------------
NOTION_API_KEY=
NOTION_DB_BIDS=
NOTION_DB_PROPOSALS=

# -------------------------------------------------------------------------
# 회사 기본정보
# -------------------------------------------------------------------------
COMPANY_NAME=주식회사 예시웹에이전시
COMPANY_CEO=우진
COMPANY_BIZ_NUM=000-00-00000
COMPANY_TECH_STACK=React,Next.js,Node.js,Python,AWS,PostgreSQL
COMPANY_TEAM_SIZE=15
COMPANY_TYPICAL_BUDGET_MIN=30000000
COMPANY_TYPICAL_BUDGET_MAX=500000000

# -------------------------------------------------------------------------
# 알림 채널 (선택)
# -------------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# -------------------------------------------------------------------------
# 시스템 설정
# -------------------------------------------------------------------------
FIT_SCORE_THRESHOLD=70
LOG_LEVEL=INFO
ENVIRONMENT=development
MONTHLY_BUDGET_USD=200
