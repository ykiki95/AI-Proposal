# =========================================================================
# AI-Proposal v2 - 환경변수 템플릿
# 이 파일을 .env로 복사 후 실제 값을 채우세요.
# =========================================================================

# -------------------------------------------------------------------------
# Anthropic Claude API (필수)
# https://console.anthropic.com/ 에서 발급
# -------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -------------------------------------------------------------------------
# Voyage AI - 한국어 임베딩 (권장)
# https://www.voyageai.com/ 에서 발급
# 미설정 시 벡터 검색 비활성화
# -------------------------------------------------------------------------
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-multilingual-2

# -------------------------------------------------------------------------
# 에이전트별 모델 매핑 (기본값 권장, 필요 시 오버라이드)
# -------------------------------------------------------------------------
MODEL_DISCOVERY=claude-haiku-4-5-20251001
MODEL_ANALYSIS=claude-sonnet-4-6
MODEL_RFP_STRUCT=claude-sonnet-4-6
MODEL_STRATEGY=claude-opus-4-7
MODEL_WRITER=claude-opus-4-7
MODEL_REVIEWER=claude-sonnet-4-6
MODEL_GRAPHICS=claude-sonnet-4-6

# -------------------------------------------------------------------------
# 나라장터 G2B OpenAPI (선택)
# https://www.data.go.kr → 나라장터 입찰공고정보 서비스 신청
# 미설정 시 샘플 데이터로 동작
# -------------------------------------------------------------------------
G2B_SERVICE_KEY=

# -------------------------------------------------------------------------
# Notion API (선택) - 발주처 승인 게이트 연동
# 미설정 시 SQLite 로컬 게이트로 fallback
# -------------------------------------------------------------------------
NOTION_API_KEY=
NOTION_DB_BIDS=
NOTION_DB_PROPOSALS=

# -------------------------------------------------------------------------
# 회사 기본정보
# -------------------------------------------------------------------------
COMPANY_NAME=주식회사 예시웹에이전시
COMPANY_CEO=우진
COMPANY_BIZ_NUM=000-00-00000
COMPANY_TECH_STACK=React,Next.js,Node.js,Python,AWS,PostgreSQL
COMPANY_TEAM_SIZE=15
COMPANY_TYPICAL_BUDGET_MIN=30000000
COMPANY_TYPICAL_BUDGET_MAX=500000000

# -------------------------------------------------------------------------
# 알림 채널 (선택)
# -------------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# -------------------------------------------------------------------------
# 시스템 설정
# -------------------------------------------------------------------------
FIT_SCORE_THRESHOLD=70
TOC_SIMILARITY_THRESHOLD=0.90
TARGET_PAGES_MIN=70
TARGET_PAGES_MAX=120
LOG_LEVEL=INFO
ENVIRONMENT=development
MONTHLY_BUDGET_USD=200
EMBEDDING_BATCH_SIZE=32
